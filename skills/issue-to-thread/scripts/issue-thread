#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"

class ContractError < StandardError; end

MANAGERS = %w[plan dev qa debug deploy security data browser docs content ops].freeze
EXECUTION = %w[in-progress done blocked scope-change].freeze
VALIDATION = %w[passed partial failed not-run].freeze
DELIVERY = %w[pending committed parent-action-required user-action-required not-required].freeze
GIT_CAPABILITY = %w[writable read-only unknown not-applicable].freeze
ACCEPTANCE = %w[passed partial failed].freeze
ARCHIVE = %w[ready-to-archive keep-active archive-after-parent-action].freeze
CALLBACK_DELIVERY = %w[automatic manual-required].freeze
CALLBACK_KIND = %w[checkpoint closeout].freeze
NEXT_ACTION = %w[child-repairing parent-decision-required none].freeze
FAILURE_CLASSIFICATION = %w[introduced-regression baseline-existing mixed unknown not-applicable].freeze

CALLBACK_EXAMPLE = {
  "callback_kind" => "closeout",
  "execution" => "done",
  "validation" => "passed",
  "validation_summary" => "all required checks passed",
  "failure_classification" => "not-applicable",
  "failure_evidence" => "all required validation passed",
  "delivery" => "parent-action-required",
  "git_capability" => "read-only",
  "commit" => "not-created",
  "issue" => "Issue 004 — /absolute/path/to/issue.md",
  "thread" => "💻 dev-evidence-citations-after-plan",
  "summary" => "Implemented and validated the approved issue.",
  "changed" => ["path/to/file.ts"],
  "acceptance" => "passed",
  "needs_parent" => "Review and commit the listed paths.",
  "archive" => "archive-after-parent-action",
  "archive_reason" => "parent commit remains",
  "next_action" => "none",
  "callback_delivery" => "automatic",
  "callback_target" => "parent-thread-id"
}.freeze

CHECKPOINT_EXAMPLE = CALLBACK_EXAMPLE.merge(
  "callback_kind" => "checkpoint",
  "execution" => "in-progress",
  "validation" => "failed",
  "validation_summary" => "pnpm check failed; classifying each failure before repair",
  "failure_classification" => "unknown",
  "failure_evidence" => "first checkpoint; compare exact failures against the approved baseline",
  "delivery" => "pending",
  "commit" => "not-created",
  "summary" => "Required validation is not complete; child is investigating and repairing.",
  "changed" => [],
  "acceptance" => "failed",
  "needs_parent" => "Monitoring checkpoint only; decision requested if a failure is baseline or scope-changing.",
  "archive" => "keep-active",
  "archive_reason" => "child is repairing validation failures",
  "next_action" => "child-repairing"
).freeze

def contract!(condition, message)
  raise ContractError, message unless condition
end

def read_input(path)
  return STDIN.read if path.nil? || path == "-"

  File.read(path)
end

def clean_field_value(raw)
  value = raw.strip
  backtick_match = value.match(/\A`([^`]*)`/)
  value = backtick_match[1] if backtick_match
  value.split(/\s+—\s+/, 2).first.strip
end

def markdown_field(text, label)
  line = text.lines.find { |candidate| candidate.match?(/\A#{Regexp.escape(label)}:\s*/) }
  raise ContractError, "missing field: #{label}" unless line

  value = clean_field_value(line.sub(/\A#{Regexp.escape(label)}:\s*/, ""))
  contract!(!value.empty? && !value.include?("<"), "unfilled field: #{label}")
  value
end

def validate_title(title)
  contract!(!title.nil? && !title.empty?, "title is required")
  contract!(!title.include?("/") && !title.include?("—"), "title cannot contain / or an em dash")
  match = title.match(/\A([^\x00-\x7F]+)\s+([a-z0-9]+(?:-[a-z0-9]+)+)\z/u)
  contract!(match, "title must be: emoji lowercase-hyphen-slug")
  slug = match[2]
  contract!(MANAGERS.include?(slug.split("-", 2).first), "title must start with a known manager")
  contract!(title.length <= 60, "title must be 60 characters or fewer")
  title
end

def validate_brief(text)
  headings = [
    "# Execution Brief",
    "## Issue",
    "## Thread",
    "## Goal / What To Build",
    "## Acceptance Criteria",
    "## Validation",
    "## Delivery Contract",
    "## Out Of Scope",
    "## Callback"
  ]
  headings.each { |heading| contract!(text.lines.any? { |line| line.strip == heading }, "missing heading: #{heading}") }

  title = validate_title(markdown_field(text, "Title"))
  target = markdown_field(text, "Target")
  target_kind = %w[local worktree projectless].find { |kind| target.match?(/\b#{kind}\b/) }
  contract!(target_kind, "Target must identify local, worktree, or projectless")

  commit_required = markdown_field(text, "Commit required")
  commit_owner = markdown_field(text, "Commit owner")
  git_capability = markdown_field(text, "Git capability")
  callback_mode = markdown_field(text, "Mode")

  contract!(%w[yes no].include?(commit_required), "Commit required must be yes or no")
  contract!(%w[child parent user none].include?(commit_owner), "invalid Commit owner")
  contract!(GIT_CAPABILITY.include?(git_capability), "invalid Git capability")
  contract!(%w[automatic manual].include?(callback_mode), "Mode must be automatic or manual")
  contract!(commit_owner == "none", "Commit owner must be none when no commit is required") if commit_required == "no"
  contract!(commit_owner != "none", "Commit owner cannot be none when a commit is required") if commit_required == "yes"
  contract!(!(git_capability == "read-only" && commit_owner == "child"), "read-only Git cannot have child commit ownership")
  contract!(git_capability == "not-applicable", "projectless target requires not-applicable Git capability") if target_kind == "projectless"

  { title: title, target: target_kind, callback: callback_mode }
end

def required_string(data, key)
  value = data[key]
  contract!(value.is_a?(String) && !value.strip.empty?, "missing or empty callback field: #{key}")
  value.strip
end

def enum_value(data, key, allowed)
  value = required_string(data, key)
  contract!(allowed.include?(value), "invalid #{key}: #{value}")
  value
end

def normalize_callback(data)
  callback_kind = enum_value(data, "callback_kind", CALLBACK_KIND)
  execution = enum_value(data, "execution", EXECUTION)
  validation = enum_value(data, "validation", VALIDATION)
  failure_classification = enum_value(data, "failure_classification", FAILURE_CLASSIFICATION)
  failure_evidence = required_string(data, "failure_evidence")
  delivery = enum_value(data, "delivery", DELIVERY)
  git_capability = enum_value(data, "git_capability", GIT_CAPABILITY)
  acceptance = enum_value(data, "acceptance", ACCEPTANCE)
  archive = enum_value(data, "archive", ARCHIVE)
  next_action = enum_value(data, "next_action", NEXT_ACTION)
  callback_delivery = enum_value(data, "callback_delivery", CALLBACK_DELIVERY)
  commit = required_string(data, "commit")

  contract!(callback_kind == "checkpoint", "in-progress execution requires a checkpoint callback") if execution == "in-progress"
  contract!(callback_kind == "closeout", "closeout callback cannot report in-progress execution") if callback_kind == "closeout"
  contract!(acceptance != "passed", "in-progress execution cannot have passed acceptance") if execution == "in-progress"
  contract!(delivery == "pending", "in-progress execution requires pending delivery") if execution == "in-progress"
  contract!(archive == "keep-active", "in-progress execution requires keep-active archive state") if execution == "in-progress"
  contract!(next_action != "none", "in-progress execution requires a next action") if execution == "in-progress"
  if callback_kind == "checkpoint" || %w[failed partial].include?(validation)
    contract!(failure_classification != "not-applicable", "failed or partial validation requires a failure classification")
  end
  contract!(acceptance == "passed", "done execution requires passed acceptance") if execution == "done"
  contract!(acceptance != "passed", "blocked execution cannot have passed acceptance") if execution == "blocked"
  contract!(!%w[failed not-run].include?(validation), "done execution cannot have failed or not-run validation") if execution == "done"

  if delivery == "committed"
    contract!(git_capability == "writable", "committed delivery requires writable Git")
    contract!(commit.match?(/\A[0-9a-f]{7,40}\z/i), "committed delivery requires a Git commit hash")
  elsif delivery == "not-required"
    contract!(commit == "not-required", "not-required delivery requires Commit=not-required")
  else
    contract!(commit == "not-created", "pending or parent/user action delivery requires Commit=not-created")
  end

  contract!(delivery != "committed", "read-only Git cannot report committed delivery") if git_capability == "read-only"
  required_string(data, "callback_target") if callback_delivery == "automatic"
  required_string(data, "callback_error") if callback_delivery == "manual-required"

  changed = data["changed"]
  changed = [changed] if changed.is_a?(String)
  contract!(changed.is_a?(Array) && changed.all? { |item| item.is_a?(String) && !item.empty? }, "changed must be a string or array of non-empty strings")
  contract!(!changed.empty? || callback_kind == "checkpoint", "closeout callback requires at least one changed path")

  {
    callback_kind: callback_kind,
    execution: execution,
    validation: validation,
    validation_summary: required_string(data, "validation_summary"),
    failure_classification: failure_classification,
    failure_evidence: failure_evidence,
    delivery: delivery,
    git_capability: git_capability,
    commit: commit,
    issue: required_string(data, "issue"),
    thread: required_string(data, "thread"),
    summary: required_string(data, "summary"),
    changed: changed,
    acceptance: acceptance,
    needs_parent: required_string(data, "needs_parent"),
    archive: archive,
    archive_reason: required_string(data, "archive_reason"),
    next_action: next_action,
    callback_delivery: callback_delivery,
    callback_error: data["callback_error"]
  }
end

def render_callback(callback)
  heading = callback[:callback_kind] == "checkpoint" ? "## Child Checkpoint" : "## Child Callback"
  lines = [
    "#{heading}: #{callback[:execution]}",
    "",
    "Callback kind: #{callback[:callback_kind]}",
    "Execution: #{callback[:execution]}",
    "Validation: #{callback[:validation]} — #{callback[:validation_summary]}",
    "Failure classification: #{callback[:failure_classification]}",
    "Failure evidence: #{callback[:failure_evidence]}",
    "Delivery: #{callback[:delivery]}",
    "Git capability: #{callback[:git_capability]}",
    "Commit: #{callback[:commit]}",
    "Issue: #{callback[:issue]}",
    "Thread: #{callback[:thread]}",
    "Summary: #{callback[:summary]}",
    "Changed: #{callback[:changed].empty? ? 'none yet' : callback[:changed].join('; ')}",
    "Acceptance: #{callback[:acceptance]}",
    "Needs parent: #{callback[:needs_parent]}",
    "Archive: #{callback[:archive]} — #{callback[:archive_reason]}",
    "Next action: #{callback[:next_action]}",
    "Callback delivery: #{callback[:callback_delivery]}"
  ]
  lines << "Callback error: #{callback[:callback_error]}" if callback[:callback_delivery] == "manual-required"
  lines.join("\n")
end

def expect_contract_error
  failed_as_expected = false
  begin
    yield
  rescue ContractError
    failed_as_expected = true
  end
  raise ContractError, "self-test expected a contract error" unless failed_as_expected
end

def self_test
  validate_title("💻 dev-evidence-citations-after-plan")
  expect_contract_error { validate_title("dev/evidence — blocked") }

  brief = <<~MD
    # Execution Brief
    ## Issue
    Issue 004
    ## Thread
    Title: `💻 dev-evidence-citations-after-plan`
    Target: `Example project, local`
    ## Goal / What To Build
    Implement the issue.
    ## Acceptance Criteria
    - [ ] Complete.
    ## Validation
    - test
    ## Delivery Contract
    Commit required: `yes`
    Commit owner: `parent`
    Git capability: `unknown`
    ## Out Of Scope
    - unrelated work
    ## Callback
    Mode: `automatic`
    Explicit parent: `omitted`
  MD
  validate_brief(brief)

  issue_004 = CALLBACK_EXAMPLE.dup
  normalize_callback(issue_004)
  normalize_callback(CHECKPOINT_EXAMPLE)
  expect_contract_error do
    normalize_callback(issue_004.merge("delivery" => "committed", "commit" => "abcdef1"))
  end
  expect_contract_error do
    normalize_callback(issue_004.merge("execution" => "blocked"))
  end
  expect_contract_error do
    normalize_callback(CHECKPOINT_EXAMPLE.merge("callback_kind" => "closeout"))
  end
  true
end

def usage
  <<~TEXT
    Usage:
      issue-thread title <title>
      issue-thread brief [file|-]
      issue-thread callback [file|-]
      issue-thread callback --example
      issue-thread self-test
  TEXT
end

begin
  command = ARGV.shift
  case command
  when "title"
    title = validate_title(ARGV.join(" "))
    puts "title_ok #{title}"
  when "brief"
    result = validate_brief(read_input(ARGV.shift))
    puts "brief_ok title=#{result[:title]} target=#{result[:target]} callback=#{result[:callback]}"
  when "callback"
    if ARGV.first == "--example"
      example_name = ARGV[1]
      contract!(example_name.nil? || example_name == "checkpoint", "unknown callback example: #{example_name}")
      puts JSON.pretty_generate(example_name == "checkpoint" ? CHECKPOINT_EXAMPLE : CALLBACK_EXAMPLE)
    else
      data = JSON.parse(read_input(ARGV.shift))
      puts render_callback(normalize_callback(data))
    end
  when "self-test"
    self_test
    puts "self_test_ok"
  else
    warn usage
    exit(command.nil? ? 0 : 1)
  end
rescue ContractError, JSON::ParserError, Errno::ENOENT => e
  warn "issue-thread: #{e.message}"
  exit 1
end
